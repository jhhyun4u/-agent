# 나라장터 공고 모니터링 → 제안결정 E2E 테스트 환경변수

# ─────────────────────────────────────────────
# 필수: 스테이징 백엔드 설정
# ─────────────────────────────────────────────

# 스테이징 API 기본 URL (프로토콜 포함)
STAGING_API_BASE_URL=https://staging.tenopa.co.kr
# 또는 로컬: http://localhost:8000

# ─────────────────────────────────────────────
# 필수: 테스트 계정 자격증명
# ─────────────────────────────────────────────

# 스테이징 환경의 E2E 테스트 계정 이메일
E2E_USER_EMAIL=test@tenopa.co.kr

# 해당 계정의 비밀번호
E2E_USER_PASSWORD=your-secure-password-here

# ─────────────────────────────────────────────
# 선택: 테스트 리소스 (없으면 자동 선택)
# ─────────────────────────────────────────────

# 테스트할 팀의 UUID
# 미설정 시: API에서 첫 번째 팀 자동 선택
E2E_TEAM_ID=

# 테스트할 공고번호 (나라장터 공고번호)
# 미설정 시: 모니터링 목록의 첫 공고 자동 선택
E2E_BID_NO=

# ─────────────────────────────────────────────
# 선택: DB 직접 검증 (teardown 최적화용)
# ─────────────────────────────────────────────

# 스테이징 Supabase URL
# 예: https://your-project.supabase.co
SUPABASE_URL=

# Supabase 서비스 롤 키 (service_role)
# 테스트 데이터 정리용으로만 사용
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# 참고: 다음은 스테이징 서버에 이미 설정되어야 함
# ─────────────────────────────────────────────

# 나라장터 API 서비스 키 (공공데이터포털 발급)
# → 스테이징 백엔드 환경변수에 이미 설정됨
# G2B_API_KEY=your-key-from-public-data-portal

# Anthropic API 키 (AI 분석용)
# → 스테이징 백엔드 환경변수에 이미 설정됨
# ANTHROPIC_API_KEY=sk-ant-...

# Supabase 연결 정보 (백엔드용)
# → 스테이징 백엔드 환경변수에 이미 설정됨
# SUPABASE_URL=https://...supabase.co
# SUPABASE_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
