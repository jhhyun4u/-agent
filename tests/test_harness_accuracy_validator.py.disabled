import pytest
import asyncio
from app.services.harness_accuracy_validator import (
    DiagnosisAccuracyValidator,
    EvaluationMetrics,
    EvaluationResult,
    PerformanceMetrics,
)


@pytest.fixture
def validator():
    """테스트용 Validator 인스턴스"""
    return DiagnosisAccuracyValidator()


@pytest.fixture
def sample_dataset(validator):
    """테스트 데이터셋 로드"""
    validator.load_dataset("data/test_datasets/harness_test_50_sections.json")
    return validator.test_dataset


class TestDiagnosisAccuracyValidator:
    """DiagnosisAccuracyValidator 단위 테스트"""

    def test_validator_initialization(self):
        """Validator 초기화 테스트"""
        validator = DiagnosisAccuracyValidator()
        assert validator.test_dataset == []
        assert validator.metrics_history == []

    def test_load_dataset(self, validator):
        """데이터셋 로드 테스트"""
        validator.load_dataset("data/test_datasets/harness_test_50_sections.json")
        assert len(validator.test_dataset) == 50
        assert validator.test_dataset[0]["id"] == "test-section-01"

    def test_dataset_structure(self, sample_dataset):
        """데이터셋 구조 검증"""
        section = sample_dataset[0]
        assert "id" in section
        assert "content" in section
        assert "section_type" in section
        assert "ground_truth" in section

    def test_ground_truth_fields(self, sample_dataset):
        """Ground Truth 필드 검증"""
        gt = sample_dataset[0]["ground_truth"]
        assert "hallucination_severity" in gt
        assert "persuasiveness_level" in gt
        assert "completeness_score" in gt
        assert "clarity_rating" in gt

    def test_calculate_confidence(self, validator):
        """신뢰도 점수 계산 테스트"""
        from app.services.harness_evaluator import EvaluationScore
        
        score = EvaluationScore(
            overall=0.8,
            hallucination=0.2,
            persuasiveness=0.8,
            completeness=0.9,
            clarity=0.7
        )
        
        confidence = validator._calculate_confidence(score)
        assert 0 <= confidence <= 1.0
        assert isinstance(confidence, float)

    def test_confidence_high_consistency(self, validator):
        """일관성 높으면 신뢰도 높음"""
        from app.services.harness_evaluator import EvaluationScore
        
        # 모든 점수가 비슷함
        score_consistent = EvaluationScore(
            overall=0.8,
            hallucination=0.8,
            persuasiveness=0.8,
            completeness=0.8,
            clarity=0.8
        )
        
        confidence_consistent = validator._calculate_confidence(score_consistent)
        assert confidence_consistent > 0.95

    def test_confidence_low_consistency(self, validator):
        """일관성 낮으면 신뢰도 낮음"""
        from app.services.harness_evaluator import EvaluationScore
        
        # 점수가 다름
        score_inconsistent = EvaluationScore(
            overall=0.5,
            hallucination=0.1,
            persuasiveness=0.9,
            completeness=0.1,
            clarity=0.9
        )
        
        confidence_inconsistent = validator._calculate_confidence(score_inconsistent)
        assert confidence_inconsistent < 0.8

    def test_classify_match_true_positive(self, validator):
        """TP 분류 테스트"""
        from app.services.harness_evaluator import EvaluationScore
        
        predicted = EvaluationScore(
            overall=0.2,
            hallucination=0.5,  # >= 0.3
            persuasiveness=0.3,
            completeness=0.3,
            clarity=0.3
        )
        
        actual = {"hallucination_severity": "high"}  # 문제 있음
        
        result = validator._classify_match(predicted, actual)
        assert result == "true_positive"

    def test_classify_match_false_positive(self, validator):
        """FP 분류 테스트"""
        from app.services.harness_evaluator import EvaluationScore
        
        predicted = EvaluationScore(
            overall=0.8,
            hallucination=0.4,  # >= 0.3
            persuasiveness=0.8,
            completeness=0.8,
            clarity=0.8
        )
        
        actual = {"hallucination_severity": "low"}  # 문제 없음
        
        result = validator._classify_match(predicted, actual)
        assert result == "false_positive"

    def test_classify_match_false_negative(self, validator):
        """FN 분류 테스트"""
        from app.services.harness_evaluator import EvaluationScore
        
        predicted = EvaluationScore(
            overall=0.9,
            hallucination=0.2,  # < 0.3
            persuasiveness=0.9,
            completeness=0.9,
            clarity=0.9
        )
        
        actual = {"hallucination_severity": "medium"}  # 문제 있음
        
        result = validator._classify_match(predicted, actual)
        assert result == "false_negative"

    def test_classify_match_true_negative(self, validator):
        """TN 분류 테스트"""
        from app.services.harness_evaluator import EvaluationScore
        
        predicted = EvaluationScore(
            overall=0.9,
            hallucination=0.1,  # < 0.3
            persuasiveness=0.9,
            completeness=0.9,
            clarity=0.9
        )
        
        actual = {"hallucination_severity": "none"}  # 문제 없음
        
        result = validator._classify_match(predicted, actual)
        assert result == "true_negative"

    def test_metrics_to_dict(self):
        """AccuracyMetrics to_dict 변환"""
        metrics = AccuracyMetrics(
            precision=0.95,
            recall=0.97,
            f1_score=0.96,
            false_negative_count=1,
            false_positive_count=2,
            true_positive_count=48,
            true_negative_count=0,
            avg_latency_seconds=2.5,
            avg_confidence_score=0.92
        )
        
        d = metrics.to_dict()
        assert d["precision"] == 0.95
        assert d["f1_score"] == 0.96
        assert "timestamp" in d

    def test_calculate_metrics_basic(self, validator):
        """기본 메트릭 계산"""
        results = ["true_positive"] * 47 + ["false_positive"] * 2 + ["false_negative"] * 1
        latencies = [2.0] * 50
        confidence_scores = [0.9] * 50
        
        metrics = validator._calculate_metrics(results, latencies, confidence_scores)
        
        assert metrics.true_positive_count == 47
        assert metrics.false_positive_count == 2
        assert metrics.false_negative_count == 1
        assert metrics.precision == pytest.approx(47 / 49)  # 47 / (47+2)
        assert metrics.recall == pytest.approx(47 / 48)  # 47 / (47+1)

    def test_metrics_summary(self, validator):
        """메트릭 요약 조회"""
        summary = validator.get_metrics_summary()
        assert summary == {}  # 측정 전

    @pytest.mark.asyncio
    async def test_measure_baseline_with_mock(self, validator, sample_dataset):
        """Baseline 측정 테스트 (Mock 사용)"""
        # 실제 API 호출 없이 메트릭 계산만 테스트
        # 이는 통합 테스트에서 수행
        assert len(validator.test_dataset) == 0
        validator.load_dataset("data/test_datasets/harness_test_50_sections.json")
        assert len(validator.test_dataset) == 50
